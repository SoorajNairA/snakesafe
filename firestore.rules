rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Reports ────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Only the owning user may read or write their own reports
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.user_id;

      // Allow creating a new report if the user_id field matches the caller
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.user_id;
    }

    // ── Hospitals ──────────────────────────────────────────────────────────
    match /hospitals/{hospitalId} {
      // Public read – lookup by anyone authenticated; no client writes
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Emergency Alerts ───────────────────────────────────────────────────
    match /emergency_alerts/{alertId} {
      // Only the owning user can read their own alerts
      allow read: if request.auth != null
        && request.auth.uid == resource.data.user_id;
      // Creation happens server-side via Admin SDK (bypasses rules)
      allow write: if false;
    }
  }
}
