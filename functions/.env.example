# Snakebite Backend — Environment Variables
# Copy this file to .env.local and fill in your values.
# For Firebase Functions, set these via:
#   firebase functions:config:set service.key="value"
# Or use .env files with the Functions Framework (Node 18+)

# ── AI Model Server ─────────────────────────────────────────────────────────
# URL of the FastAPI prediction server (no trailing slash)
AI_MODEL_URL=http://localhost:8000

# ── Email Alerts (Nodemailer / SMTP) ────────────────────────────────────────
# SMTP credentials for sending emergency email alerts
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Snakebite Alert <soorajnair282005@gmail.com>

# ── FCM (Firebase Cloud Messaging) ──────────────────────────────────────────
# Set via firebase-admin which uses GOOGLE_APPLICATION_CREDENTIALS automatically.
# No extra variable needed when deployed to Cloud Functions.
